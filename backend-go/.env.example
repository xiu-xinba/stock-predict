HOST=127.0.0.1
PORT=5070
# 生产环境务必设置为 production，开发模式会放宽安全限制
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
TRUSTED_PROXIES=
RUN_DATABASE_MIGRATIONS=false
# 安全说明：生产环境必须设置至少 32 字符的强随机令牌，切勿使用空值或默认值部署
ADMIN_TOKEN=
# Remote full public-fund universe. Disable auto sync with FUND_AUTO_SYNC_ON_START=false
# when running offline with a local CSV/store.
FUND_UNIVERSE_URL=https://fund.eastmoney.com/js/fundcode_search.js
# Eastmoney latest NAV ranking metrics: unit NAV, daily growth, 1M/1Y returns.
# Blank uses the runtime default rankhandler URL for the latest one-year window.
FUND_METRICS_URL=
# Auto-fill the local fund store on startup when it is still too small.
FUND_AUTO_SYNC_ON_START=false
FUND_AUTO_SYNC_MIN_COUNT=1000
# Disable stock auto sync on startup when running offline.
STOCK_AUTO_SYNC_ON_START=false
MARKET_SYNC_ENABLED=false
# Use Tencent listed-fund quotes and Eastmoney fund valuation for watchlist refreshes.
FUND_REALTIME_QUOTES_ENABLED=true
# Optional CSV with fund_code, fund_name, and fund_type columns for local fund universe imports.
FUND_SYNC_CSV_PATH=
READ_TIMEOUT_SECONDS=8
WRITE_TIMEOUT_SECONDS=12
SHUTDOWN_TIMEOUT_SECONDS=8
# Cache TTL for stock/fund detail responses (minutes, default 5)
CACHE_TTL_MINUTES=5
# External API base URLs (override for testing or regional mirrors)
# EASTMONEY_BASE_URL=https://push2his.eastmoney.com
# TENCENT_QUOTE_BASE_URL=https://qt.gtimg.cn
# BiyingAPI requires a licence. Put your real licence in local .env only.
BIYING_API_URL=https://api.biyingapi.com
BIYING_API_TOKEN=
# PostgreSQL owner/migration identity and least-privilege API runtime identity.
# Keep both passwords mandatory and distinct. Production DSNs should enable TLS.
POSTGRES_DB=stock_predict
POSTGRES_USER=stock_owner
POSTGRES_PASSWORD=CHANGE_ME_OWNER
POSTGRES_RUNTIME_USER=stock_app
POSTGRES_RUNTIME_PASSWORD=CHANGE_ME_RUNTIME
MIGRATION_DATABASE_URL=postgres://stock_owner:CHANGE_ME_OWNER@localhost:5432/stock_predict?sslmode=disable
DATABASE_URL=postgres://stock_app:CHANGE_ME_RUNTIME@localhost:5432/stock_predict?sslmode=disable
# Local AKShare microservice. Start it with scripts\start-akshare-service.ps1.
AKSHARE_URL=http://localhost:8900
AKSHARE_SERVICE_TOKEN=
