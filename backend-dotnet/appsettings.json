{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "Env": "development",
    "Debug": true,
    "CorsOrigins": "http://localhost:5173",
    "EastMoney": {
      "BaseUrl": "https://fund.eastmoney.com",
      "RequestDelay": 0.5
    },
    "Model": {
      "Path": "./Models/model_v1.onnx",
      "CacheTtl": 300
    },
    "Market": {
      "CacheTtl": 30
    },
    "Fund": {
      "CacheTtl": 30
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=./data/stockpredict.db"
  }
}
